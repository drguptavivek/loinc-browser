# LOINC Browser listen address. CLI --addr or --port overrides this.
LOINC_BROWSER_ADDR=:9005

# Alternative for platforms that provide PORT.
# PORT=9005

# Editable Markdown docs served by the MCP agent resources.
LOINC_AGENT_DOCS_DIR=./docs/agent

# Official LOINC Search API proxy. Credentials can be entered in the UI and
# optionally saved encrypted in the local file-backed KV store.
LOINC_OFFICIAL_API_BASE_URL=https://loinc.regenstrief.org/searchapi
LOINC_APP_KEY_PATH=./data/loinc-browser-app.key
LOINC_KV_PATH=./data/loinc-browser-kv.json

# Generated local Lucene-style search index.
LOINC_SEARCH_INDEX_PATH=./data/loinc-search.bleve
